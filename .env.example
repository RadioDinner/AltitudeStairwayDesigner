# Supabase — copy to .env.local and fill in (ADR 0007, 0032).
# Client-safe (exposed to the browser bundle / iframe embed):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER expose to the client bundle or the iframe (ADR 0032):
SUPABASE_SERVICE_ROLE_KEY=

# Transactional email for the PO/RFQ pipeline (ADR 0025) — added when that lands.
# EMAIL_API_KEY=
